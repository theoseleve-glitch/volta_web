{%- comment -%}
  main-volta-product.liquid
  Replaces Dawn's main-product. 50/50 split: sticky media left, scrolling info right.
  Scroll-scrubbed hero image (scale + rotation). Stacks on mobile.
{%- endcomment -%}

{%- assign product_form_id = 'product-form-' | append: section.id -%}
{%- assign first_variant = product.selected_or_first_available_variant -%}

<section class="v-product" data-volta-product data-product-id="{{ product.id }}">
  <div class="v-container v-product__grid">

    {%- comment -%} ── Left: sticky media ─────────────────────────────────── {%- endcomment -%}
    <div class="v-product__media-col">
      <div class="v-product__media-inner" data-volta-product-media>
        {%- if product.featured_image != blank -%}
          {{ product.featured_image | image_url: width: 1400 | image_tag:
            class: 'v-product__img',
            id: 'VoltaProductImg-' | append: section.id,
            widths: '400,700,1000,1400',
            sizes: '(min-width: 900px) 50vw, 100vw',
            loading: 'eager',
            fetchpriority: 'high',
            alt: product.featured_image.alt | default: product.title
          }}
        {%- else -%}
          <div class="v-product__img v-product__img--placeholder" aria-hidden="true"></div>
        {%- endif -%}

        <ul class="v-product__thumbs" role="list">
          {%- for media in product.media limit: 4 -%}
            <li>
              <button
                type="button"
                class="v-product__thumb{% if forloop.first %} is-active{% endif %}"
                data-media-url="{{ media | image_url: width: 1400 }}"
                aria-label="{{ 'products.product.media.image_available' | t: index: forloop.index }}"
              >
                {{ media | image_url: width: 120 | image_tag: loading: 'lazy', alt: '' }}
              </button>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>

    {%- comment -%} ── Right: scrolling info ──────────────────────────────── {%- endcomment -%}
    <div class="v-product__info-col">
      <nav class="v-product__breadcrumb v-mono" aria-label="{{ 'sections.volta_product.breadcrumb_label' | t }}">
        <a href="{{ routes.all_products_collection_url }}" data-cursor="hover">{{ 'sections.volta_product.breadcrumb_root' | t }}</a>
        <span aria-hidden="true"> / </span>
        <span>{{ product.title }}</span>
      </nav>

      <h1 class="v-product__title v-display v-reveal">{{ product.title }}</h1>

      <div class="v-product__pricing v-reveal">
        <div class="v-product__price" data-volta-price>
          <span class="v-product__price-regular">{{ first_variant.price | money }}</span>
          {%- if first_variant.compare_at_price > first_variant.price -%}
            <span class="v-product__price-compare">{{ first_variant.compare_at_price | money }}</span>
          {%- endif -%}
        </div>
        <div class="v-product__price v-product__price--sub" data-volta-price-sub hidden>
          <span class="v-product__price-regular" data-volta-price-sub-value>—</span>
          <span class="v-mono v-product__price-badge">−30%</span>
        </div>
      </div>

      {%- if product.description != blank -%}
        <div class="v-product__tagline v-reveal">
          {{ product.description | strip_html | truncatewords: 22 }}
        </div>
      {%- endif -%}

      {%- comment -%} ── Pack-size variant picker ───────────────────────── {%- endcomment -%}
      {%- if product.has_only_default_variant == false -%}
        <fieldset class="v-product__variants v-reveal">
          <legend class="v-mono v-product__label">{{ 'sections.volta_product.pack_size' | t }}</legend>
          <div class="v-product__variant-grid">
            {%- for variant in product.variants -%}
              <label class="v-product__variant{% if variant == first_variant %} is-active{% endif %}">
                <input
                  type="radio"
                  name="variant"
                  value="{{ variant.id }}"
                  data-volta-variant
                  {% if variant == first_variant %}checked{% endif %}
                  {% unless variant.available %}disabled{% endunless %}
                >
                <span class="v-product__variant-name">{{ variant.title }}</span>
                <span class="v-mono v-product__variant-price">{{ variant.price | money }}</span>
              </label>
            {%- endfor -%}
          </div>
        </fieldset>
      {%- endif -%}

      {%- comment -%} ── Quantity ───────────────────────────────────────── {%- endcomment -%}
      <div class="v-product__qty v-reveal">
        <label class="v-mono v-product__label" for="VoltaQty-{{ section.id }}">
          {{ 'products.product.quantity.label' | t }}
        </label>
        <quantity-input class="v-product__qty-input">
          <button type="button" name="minus" class="v-product__qty-btn" aria-label="{{ 'products.product.quantity.decrease' | t: product: product.title }}">−</button>
          <input
            type="number"
            id="VoltaQty-{{ section.id }}"
            name="quantity"
            value="1"
            min="1"
            step="1"
            class="quantity__input v-product__qty-field"
            data-volta-qty
          >
          <button type="button" name="plus" class="v-product__qty-btn" aria-label="{{ 'products.product.quantity.increase' | t: product: product.title }}">+</button>
        </quantity-input>
      </div>

      {%- comment -%} ── Add to cart ────────────────────────────────────── {%- endcomment -%}
      <product-form class="v-product__form" data-section-id="{{ section.id }}">
        {%- form 'product',
          product,
          id: product_form_id,
          class: 'v-product__add-form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form'
        -%}
          <input type="hidden" name="id" value="{{ first_variant.id }}" data-volta-variant-id>
          <button
            type="submit"
            name="add"
            class="v-btn v-btn--primary v-btn--huge v-magnetic"
            data-cursor="hover"
            data-volta-add-to-cart
            {% unless first_variant.available %}disabled{% endunless %}
          >
            <span class="v-product__add-label">
              {% if first_variant.available %}
                {{ 'sections.volta_product.add_to_cart' | t }}
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </span>
          </button>
        {%- endform -%}
      </product-form>

      {%- comment -%} ── Trust bar ──────────────────────────────────────── {%- endcomment -%}
      <ul class="v-product__trust v-reveal" role="list">
        <li><span aria-hidden="true">🚚</span> {{ 'sections.volta_product.trust.delivery' | t }}</li>
        <li><span aria-hidden="true">🍃</span> {{ 'sections.volta_product.trust.natural' | t }}</li>
        <li><span aria-hidden="true">🌱</span> {{ 'sections.volta_product.trust.vegan' | t }}</li>
        <li><span aria-hidden="true">🇫🇷</span> {{ 'sections.volta_product.trust.origin' | t }}</li>
      </ul>

      {%- comment -%} ── Accordions ─────────────────────────────────────── {%- endcomment -%}
      <div class="v-product__accordions v-reveal">
        {%- for block in section.blocks -%}
          {%- if block.type == 'accordion' -%}
            <details class="v-product__accordion" {{ block.shopify_attributes }}>
              <summary class="v-mono v-product__accordion-summary">
                {{ block.settings.heading }}
                <span class="v-product__accordion-icon" aria-hidden="true">+</span>
              </summary>
              <div class="v-product__accordion-body">
                {{ block.settings.body }}
              </div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .v-product { padding-block: var(--space-16) var(--space-section); background: var(--volta-cream); }

  .v-product__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  .v-product__media-col { position: relative; }
  .v-product__media-inner {
    position: sticky;
    top: calc(var(--space-20));
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .v-product__img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 12px;
    transform-origin: center;
    will-change: transform;
  }
  .v-product__img--placeholder { background: linear-gradient(135deg, var(--volta-green-dim), var(--volta-cream-warm)); }

  .v-product__thumbs {
    display: flex;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .v-product__thumb {
    background: transparent;
    border: 1.5px solid transparent;
    border-radius: 8px;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    width: 64px;
    height: 64px;
    transition: border-color var(--duration-fast);
  }
  .v-product__thumb.is-active { border-color: var(--volta-ink); }
  .v-product__thumb img { width: 100%; height: 100%; object-fit: cover; }

  .v-product__info-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .v-product__breadcrumb { color: color-mix(in srgb, var(--volta-ink) 60%, transparent); }
  .v-product__breadcrumb a { color: inherit; text-decoration: none; }
  .v-product__title {
    font-size: var(--text-3xl);
    letter-spacing: -0.03em;
    margin: 0;
  }

  .v-product__pricing { display: flex; flex-direction: column; gap: var(--space-1); }
  .v-product__price { display: flex; gap: var(--space-3); align-items: baseline; font-size: var(--text-xl); }
  .v-product__price-compare { opacity: 0.5; text-decoration: line-through; }
  .v-product__price-badge {
    background: var(--volta-green);
    color: var(--volta-ink);
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 500;
  }

  .v-product__tagline {
    font-size: var(--text-lg);
    line-height: 1.4;
    color: color-mix(in srgb, var(--volta-ink) 75%, transparent);
  }

  .v-product__label { color: color-mix(in srgb, var(--volta-ink) 70%, transparent); }

  .v-product__variants { border: 0; padding: 0; margin: 0; }
  .v-product__variant-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-2); margin-top: var(--space-2); }
  .v-product__variant {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4);
    border: 1.5px solid color-mix(in srgb, var(--volta-ink) 15%, transparent);
    border-radius: 8px;
    cursor: pointer;
    transition: border-color var(--duration-fast), background var(--duration-fast);
  }
  .v-product__variant input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .v-product__variant.is-active,
  .v-product__variant:has(input:checked) { border-color: var(--volta-ink); background: color-mix(in srgb, var(--volta-green) 8%, transparent); }

  .v-product__qty { display: flex; flex-direction: column; gap: var(--space-2); }
  .v-product__qty-input { display: inline-flex; align-items: center; border: 1.5px solid var(--volta-ink); border-radius: 999px; width: fit-content; }
  .v-product__qty-btn { background: transparent; border: 0; width: 44px; height: 44px; font-size: var(--text-xl); cursor: pointer; }
  .v-product__qty-field { width: 48px; text-align: center; border: 0; background: transparent; font-family: var(--font-mono); font-size: var(--text-base); -moz-appearance: textfield; }
  .v-product__qty-field::-webkit-outer-spin-button,
  .v-product__qty-field::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  .v-btn--huge { padding: var(--space-6) var(--space-12); font-size: var(--text-sm); width: 100%; }

  .v-product__trust {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: var(--space-4) 0;
    border-block: 1px solid color-mix(in srgb, var(--volta-ink) 10%, transparent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
  }
  .v-product__trust li { display: flex; align-items: center; gap: var(--space-2); }

  .v-product__accordions { display: flex; flex-direction: column; }
  .v-product__accordion { border-bottom: 1px solid color-mix(in srgb, var(--volta-ink) 10%, transparent); }
  .v-product__accordion-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4);
    cursor: pointer;
    list-style: none;
    color: var(--volta-ink);
  }
  .v-product__accordion-summary::-webkit-details-marker { display: none; }
  .v-product__accordion[open] .v-product__accordion-icon { transform: rotate(45deg); }
  .v-product__accordion-icon { transition: transform var(--duration-base); display: inline-block; }
  .v-product__accordion-body { padding-bottom: var(--space-4); font-size: var(--text-base); color: color-mix(in srgb, var(--volta-ink) 80%, transparent); }

  @media (max-width: 900px) {
    .v-product__grid { grid-template-columns: 1fr; gap: var(--space-8); }
    .v-product__media-inner { position: static; }
  }

  @media (prefers-reduced-motion: reduce) {
    .v-product__img { transform: none !important; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.volta_product.name",
  "blocks": [
    {
      "type": "accordion",
      "name": "t:sections.volta_product.blocks.accordion.name",
      "settings": [
        { "type": "text", "id": "heading", "label": "t:sections.volta_product.blocks.accordion.settings.heading.label", "default": "Ingrédients" },
        { "type": "richtext", "id": "body", "label": "t:sections.volta_product.blocks.accordion.settings.body.label", "default": "<p>Liste complète des ingrédients.</p>" }
      ]
    }
  ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
