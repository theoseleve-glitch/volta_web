{%- comment -%}
  volta-hero-v1.liquid — V1 orange-image hero (single-product Golden Kick launch)
  Spec: chat 2026-05-15. Cream page, lightning-face logo top-left, cart top-right,
  orange Golden-Kick hero image full-bleed, CTA pill auto-enables when the
  merchant binds the Golden Kick product in Theme Editor.
{%- endcomment -%}

{{ 'volta-hero-v1.css' | asset_url | stylesheet_tag }}

{%- assign hero_product = section.settings.hero_product -%}
{%- assign variant = hero_product.first_available_variant -%}

<section class="v-hero-v1" aria-labelledby="hero-v1-heading-{{ section.id }}">
  <a href="{{ routes.root_url }}" class="v-hero-v1__logo" aria-label="{{ 'accessibility.home' | t: shop_name: shop.name }}">
    <img src="{{ 'volta-logo.svg' | asset_url }}"
         alt="{{ shop.name }}"
         width="80" height="80"
         loading="eager"
         fetchpriority="high">
  </a>

  <a href="{{ routes.cart_url }}"
     class="v-hero-v1__cart"
     aria-label="{% if cart.item_count > 0 %}{{ 'general.cart.view' | t: count: cart.item_count }}{% else %}{{ 'general.cart.view_empty_cart' | t }}{% endif %}">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22" aria-hidden="true">
      <path d="M6 7h12l-1.5 11h-9z"/>
      <path d="M9 7V5a3 3 0 0 1 6 0v2"/>
    </svg>
    {%- if cart.item_count > 0 -%}
      <span class="v-hero-v1__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
    {%- endif -%}
  </a>

  {%- comment -%} SR-only h1 — the visible hero text is baked into the image, but assistive tech needs a heading. {%- endcomment -%}
  <h1 id="hero-v1-heading-{{ section.id }}" class="v-hero-v1__sr-heading">
    {{ 'sections.volta_hero_v1.title_default' | t }}
  </h1>

  <img class="v-hero-v1__bg"
       src="{{ 'volta-hero-bg.png' | asset_url }}"
       alt="{{ 'sections.volta_hero_v1.bg_alt' | t }}"
       width="2400" height="1260"
       loading="eager"
       fetchpriority="high">

  <div class="v-hero-v1__cta-area">
    {%- if variant and variant.available -%}
      <form action="{{ routes.cart_add_url }}" method="post" class="v-hero-v1__buy-form">
        <input type="hidden" name="id" value="{{ variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <input type="hidden" name="return_to" value="/checkout">
        <button type="submit" class="v-hero-v1__cta">
          {%- if section.settings.cta_label != blank -%}{{ section.settings.cta_label }}{%- else -%}{{ 'sections.volta_hero_v1.cta_default' | t }}{%- endif -%}
          <span class="v-hero-v1__cta-price">{{ variant.price | money }}</span>
        </button>
      </form>
    {%- else -%}
      <button type="button" class="v-hero-v1__cta v-hero-v1__cta--disabled" aria-disabled="true" disabled>
        {{ 'sections.volta_hero_v1.cta_unavailable' | t }}
      </button>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.volta_hero_v1.name",
  "tag": "section",
  "class": "v-hero-v1-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.volta_hero_v1.settings.product_header"
    },
    {
      "type": "product",
      "id": "hero_product",
      "label": "t:sections.volta_hero_v1.settings.product_label",
      "info": "t:sections.volta_hero_v1.settings.product_info"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:sections.volta_hero_v1.settings.cta_label_label"
    }
  ],
  "presets": [
    { "name": "t:sections.volta_hero_v1.name" }
  ]
}
{% endschema %}
