{%- comment -%}
  volta-products.liquid
  Asymmetric 4-product grid. One featured larger, others stagger. Each card
  has parallax image on scroll, scales on hover, multi-layered shadow lift.
{%- endcomment -%}

{%- liquid
  assign products = collections[section.settings.collection].products | default: (all_products | limit: 4)
-%}

<section id="products" class="v-products" aria-labelledby="products-heading-{{ section.id }}">
  <div class="v-container">
    <header class="v-products__header v-reveal">
      <p class="v-mono v-products__eyebrow">{{ 'sections.volta_products.eyebrow' | t }}</p>
      <h2 id="products-heading-{{ section.id }}" class="v-products__title v-display">
        {{ 'sections.volta_products.title' | t }}
      </h2>
    </header>

    <div class="v-products__grid">
      {%- for product in products limit: 4 -%}
        <article class="v-products__card v-products__card--{{ forloop.index }} v-reveal">
          <a class="v-products__link" href="{{ product.url }}" data-cursor="view" data-cursor-label="{{ 'sections.volta_products.cursor_view' | t }}">
            <div class="v-products__media">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 800 | image_tag:
                  class: 'v-products__img v-parallax',
                  widths: '300,500,800,1200',
                  sizes: '(min-width: 900px) 40vw, 90vw',
                  loading: 'lazy',
                  alt: product.featured_image.alt | default: product.title
                }}
              {%- else -%}
                <div class="v-products__img v-products__img--placeholder" aria-hidden="true"></div>
              {%- endif -%}
            </div>
            <div class="v-products__meta">
              <span class="v-mono v-products__price">{{ product.price | money_without_trailing_zeros }}</span>
              <h3 class="v-products__name">{{ product.title | default: 'Volta Shot' }}</h3>
              <p class="v-products__tagline v-mono">
                {{- product.metafields.volta.tagline | default: product.type | default: '' -}}
              </p>
            </div>
            <span class="v-products__cta v-mono">
              {{ 'sections.volta_products.card_cta' | t }} <span aria-hidden="true">→</span>
            </span>
          </a>
        </article>
      {%- endfor -%}

      {%- if products.size == 0 -%}
        {%- for i in (1..4) -%}
          <article class="v-products__card v-products__card--{{ i }} v-reveal">
            <a class="v-products__link" href="#" aria-disabled="true">
              <div class="v-products__media">
                <div class="v-products__img v-products__img--placeholder" aria-hidden="true"></div>
              </div>
              <div class="v-products__meta">
                <span class="v-mono v-products__price">€3,00</span>
                <h3 class="v-products__name">{{ 'sections.volta_products.placeholder_name' | t }} {{ i }}</h3>
                <p class="v-products__tagline v-mono">{{ 'sections.volta_products.placeholder_tagline' | t }}</p>
              </div>
            </a>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .v-products {
    padding-block: var(--space-section);
    background: var(--volta-cream);
  }
  .v-products__header { margin-bottom: var(--space-16); }
  .v-products__eyebrow { color: var(--volta-green); margin: 0 0 var(--space-2); }
  .v-products__title {
    font-size: var(--text-3xl);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    margin: 0;
    max-width: 12ch;
  }

  .v-products__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .v-products__card {
    position: relative;
    transition: transform var(--duration-slow) var(--ease-out-expo);
  }
  .v-products__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .v-products__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: var(--volta-cream-warm);
    border-radius: 8px;
    margin-bottom: var(--space-4);
    box-shadow: 0 4px 20px -8px var(--volta-shadow);
    transition: box-shadow var(--duration-base) var(--ease-out-expo), transform var(--duration-base) var(--ease-out-expo);
  }
  .v-products__link:hover .v-products__media {
    box-shadow: 0 12px 50px -12px var(--volta-shadow-strong), 0 2px 6px var(--volta-shadow);
    transform: translateY(-4px);
  }
  .v-products__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out-expo);
  }
  .v-products__img--placeholder {
    background: linear-gradient(135deg, var(--volta-green-dim), var(--volta-cream-warm));
  }
  .v-products__link:hover .v-products__img { transform: scale(1.04); }

  .v-products__meta { display: flex; flex-direction: column; gap: var(--space-1); }
  .v-products__price { color: var(--volta-ink); opacity: 0.7; }
  .v-products__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
  }
  .v-products__tagline { color: color-mix(in srgb, var(--volta-ink) 60%, transparent); margin: 0; }
  .v-products__cta {
    display: inline-block;
    margin-top: var(--space-3);
    color: var(--volta-ink);
  }

  @media (max-width: 900px) {
    .v-products__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .v-products__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.volta_products.name",
  "settings": [
    { "type": "collection", "id": "collection", "label": "t:sections.volta_products.settings.collection.label" }
  ],
  "presets": [{ "name": "t:sections.volta_products.name" }]
}
{% endschema %}
