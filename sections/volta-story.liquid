{%- comment -%}
  volta-story.liquid
  Premium editorial story. Vertical flow of alternating chapters
  (image left/right, copy opposite). Roman numerals as chapter markers.
  Muted typography, generous whitespace, no horizontal scroll.
{%- endcomment -%}

{%- assign romans = 'I,II,III,IV,V,VI,VII,VIII' | split: ',' -%}

<section id="story" class="v-story" aria-labelledby="story-heading-{{ section.id }}">
  <div class="v-container">
    <header class="v-story__intro v-reveal">
      <p class="v-mono v-story__eyebrow">{{ 'sections.volta_story.eyebrow' | t }}</p>
      <h2 id="story-heading-{{ section.id }}" class="v-story__title v-display">
        {{ 'sections.volta_story.title' | t }}
      </h2>
      {%- if section.settings.intro != blank -%}
        <p class="v-story__intro-body">{{ section.settings.intro }}</p>
      {%- endif -%}
    </header>

    <div class="v-story__chapters">
      {%- for block in section.blocks -%}
        {%- assign is_odd = forloop.index | modulo: 2 -%}
        <article class="v-story__chapter v-story__chapter--{% if is_odd == 1 %}right{% else %}left{% endif %} v-reveal" {{ block.shopify_attributes }}>
          <div class="v-story__chapter-media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1400 | image_tag:
                class: 'v-story__img',
                widths: '600,900,1200,1400',
                sizes: '(min-width: 900px) 45vw, 90vw',
                loading: 'lazy',
                alt: block.settings.image.alt | default: block.settings.heading
              }}
            {%- else -%}
              <div class="v-story__img v-story__img--placeholder" aria-hidden="true"></div>
            {%- endif -%}
          </div>
          <div class="v-story__chapter-copy">
            <span class="v-mono v-story__chapter-num">
              {{ romans[forloop.index0] }}
              <span class="v-story__chapter-num-sep">·</span>
              {{ 'sections.volta_story.chapter_label' | t }}
            </span>
            <h3 class="v-story__chapter-heading v-display">{{ block.settings.heading }}</h3>
            <div class="v-story__chapter-body">{{ block.settings.body }}</div>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .v-story {
    background: var(--volta-cream);
    color: var(--volta-ink);
    padding-block: var(--space-section);
  }

  .v-story__intro {
    max-width: 720px;
    margin: 0 auto var(--space-section);
    text-align: center;
  }
  .v-story__eyebrow {
    color: color-mix(in srgb, var(--volta-ink) 55%, transparent);
    margin: 0 0 var(--space-4);
  }
  .v-story__title {
    font-size: clamp(40px, 5vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 400;
    margin: 0;
    text-wrap: balance;
  }
  .v-story__intro-body {
    margin: var(--space-5) auto 0;
    font-size: var(--text-lg);
    line-height: 1.55;
    color: color-mix(in srgb, var(--volta-ink) 75%, transparent);
    max-width: 52ch;
  }

  .v-story__chapters {
    display: flex;
    flex-direction: column;
    gap: clamp(80px, 12vw, 160px);
  }

  .v-story__chapter {
    display: grid;
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
  }
  .v-story__chapter--right { grid-template-columns: 1fr 1fr; }
  .v-story__chapter--left  { grid-template-columns: 1fr 1fr; }

  .v-story__chapter--left .v-story__chapter-media  { order: 2; }
  .v-story__chapter--left .v-story__chapter-copy   { order: 1; padding-right: var(--space-6); }
  .v-story__chapter--right .v-story__chapter-copy  { padding-left: var(--space-6); }

  .v-story__chapter-media {
    position: relative;
  }
  .v-story__img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 2px;
    display: block;
    filter: saturate(0.95);
  }
  .v-story__img--placeholder {
    background: linear-gradient(135deg, var(--volta-green-dim), var(--volta-cream-warm));
  }

  .v-story__chapter-copy {
    max-width: 48ch;
  }
  .v-story__chapter-num {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: color-mix(in srgb, var(--volta-ink) 55%, transparent);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }
  .v-story__chapter-num-sep { opacity: 0.4; }

  .v-story__chapter-heading {
    font-size: clamp(32px, 4vw, 56px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 0 0 var(--space-6);
    text-wrap: balance;
  }

  .v-story__chapter-body {
    font-size: var(--text-lg);
    line-height: 1.65;
    color: color-mix(in srgb, var(--volta-ink) 82%, transparent);
  }
  .v-story__chapter-body p { margin: 0 0 var(--space-4); }
  .v-story__chapter-body p:last-child { margin-bottom: 0; }

  /* Subtle editorial divider under each chapter heading */
  .v-story__chapter-heading::after {
    content: '';
    display: block;
    width: 48px;
    height: 1px;
    background: var(--volta-ink);
    margin-top: var(--space-5);
    opacity: 0.4;
  }

  @media (max-width: 900px) {
    .v-story__chapter--right,
    .v-story__chapter--left { grid-template-columns: 1fr; }
    .v-story__chapter--left .v-story__chapter-media,
    .v-story__chapter--right .v-story__chapter-media { order: 1; }
    .v-story__chapter--left .v-story__chapter-copy,
    .v-story__chapter--right .v-story__chapter-copy { order: 2; padding: 0; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.volta_story.name",
  "settings": [
    { "type": "richtext", "id": "intro", "label": "Texte d'introduction (optionnel)" }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "panel",
      "name": "t:sections.volta_story.blocks.panel.name",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "t:sections.volta_story.blocks.panel.settings.image.label" },
        { "type": "text", "id": "heading", "label": "t:sections.volta_story.blocks.panel.settings.heading.label", "default": "Origine" },
        { "type": "richtext", "id": "body", "label": "t:sections.volta_story.blocks.panel.settings.body.label", "default": "<p>Une idée simple.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.volta_story.name",
      "blocks": [{ "type": "panel" }, { "type": "panel" }, { "type": "panel" }, { "type": "panel" }]
    }
  ]
}
{% endschema %}
