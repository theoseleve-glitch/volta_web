{%- comment -%}
  volta-mascot.liquid
  Uses the actual logo v1 PNG. Whole-image animations only — no SVG part IDs.
  volta-mascot.js treats this as "png mode" and skips part-specific tweens.

  Accepts:
    - variant: 'hero' | 'band' | 'cart' | 'drawer' | '404' | 'preloader'
    - scroll:  'charge' | 'idle' | 'discharge'
{%- endcomment -%}
{%- assign variant = variant | default: 'hero' -%}
{%- assign scroll = scroll | default: 'idle' -%}

<div
  class="v-mascot v-mascot--{{ variant }}"
  data-volta-mascot
  data-mascot-state="idle"
  data-mascot-scroll="{{ scroll }}"
  role="presentation"
  aria-hidden="true"
>
  <img
    class="v-mascot__img"
    src="{{ 'volta-logo-v2.png' | asset_url }}"
    alt=""
    loading="{% if variant == 'hero' or variant == 'preloader' %}eager{% else %}lazy{% endif %}"
    {% if variant == 'hero' or variant == 'preloader' %}fetchpriority="high"{% endif %}
    draggable="false"
  >
</div>

{% stylesheet %}
  .v-mascot {
    position: relative;
    display: inline-block;
    z-index: var(--z-mascot);
    will-change: transform;
  }
  .v-mascot__img { width: 100%; height: 100%; object-fit: contain; display: block; user-select: none; -webkit-user-drag: none; }

  .v-mascot--hero {
    position: absolute;
    right: 4vw;
    top: 50%;
    transform: translateY(-50%);
    width: 30vw;
    max-width: 440px;
    aspect-ratio: 1 / 1;
  }
  .v-mascot--band {
    position: absolute;
    right: 6vw;
    bottom: 6vh;
    width: 18vw;
    max-width: 260px;
    aspect-ratio: 1 / 1;
    transform: rotate(-6deg);
  }
  .v-mascot--drawer    { width: 180px; height: 180px; }
  .v-mascot--404       { width: 320px; height: 320px; }
  .v-mascot--preloader { width: 320px; height: 320px; }

  @media (max-width: 768px) {
    .v-mascot--hero,
    .v-mascot--band { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .v-mascot { animation: none !important; }
  }
{% endstylesheet %}
